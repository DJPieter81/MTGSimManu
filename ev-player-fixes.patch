@@ -228,6 +228,30 @@ class EVPlayer:
             candidates.append(Play("cast_spell", spell, targets, ev,
                                    f"{spell.name} (EV={ev:.1f})"))
 
+        # Patch C: Score cycling plays (Living End, Street Wraith, etc.)
+        for card in me.hand:
+            if game.can_cycle(self.player_idx, card):
+                # Don't cycle if we can also hard-cast it profitably
+                if game.can_cast(self.player_idx, card):
+                    continue
+                # Base cycling EV: slightly less than casting a cantrip (cycling
+                # doesn't trigger prowess, storm count, etc.)
+                cycle_ev = 2.5
+                if snap.my_hand_size <= 2:
+                    cycle_ev += 2.0  # need cards
+                # Graveyard value: combo decks want creatures in GY
+                if self.archetype == 'combo' and card.template.is_creature:
+                    cycle_ev += 1.5  # fills GY for Living End
+                # Street Wraith (pay 2 life): slightly less valuable
+                cost_data = card.template.cycling_cost_data
+                if cost_data and cost_data.get('life', 0) > 0:
+                    life_cost = cost_data['life']
+                    if me.life <= life_cost + 3:
+                        continue  # too low on life
+                    cycle_ev -= life_cost * 0.5
+                candidates.append(Play("cycle", card, [], cycle_ev,
+                                       f"Cycle {card.name} (EV={cycle_ev:.1f})"))
+
         if not candidates:
             return None
 
@@ -427,7 +451,8 @@ class EVPlayer:
             ev += min(cmc / snap.my_mana, 1.0) * 2.0
 
         # ── Mana holdback penalty ──
-        if p.holdback_applies and snap.turn_number >= p.holdback_min_turn:
+        # Patch 6: skip holdback when opponent has no clock — deploy proactively
+        if p.holdback_applies and snap.turn_number >= p.holdback_min_turn and snap.opp_clock < 10:
             has_instant = any(
                 c.template.is_instant and (
                     'removal' in getattr(c.template, 'tags', set()) or
@@ -476,10 +501,13 @@ class EVPlayer:
 
         # ── Survival mode: when facing lethal, boost survival plays ──
         if snap.am_dead_next:
+            # Patch B: scale bonus by threat size — big creatures need answers more
+            avg_opp_power = snap.opp_power / max(1, snap.opp_creature_count)
+            power_scale = min(1.0, avg_opp_power / 3.0)  # full bonus at 3+ avg power
             if 'removal' in tags and snap.opp_creature_count > 0:
-                ev += p.survival_removal_bonus
+                ev += p.survival_removal_bonus * power_scale
             if t.is_creature and (t.toughness or 0) >= 3:
-                ev += p.survival_blocker_bonus
+                ev += p.survival_blocker_bonus * power_scale
             if 'board_wipe' in tags and snap.opp_creature_count > 0:
                 ev += p.survival_wrath_bonus
 
@@ -647,12 +675,51 @@ class EVPlayer:
         for creature in valid:
             oracle = (creature.template.oracle_text or "").lower()
             if "discard a card" in oracle and "+1/+1" in oracle:
-                discardable = [c for c in me.hand
-                               if not c.template.is_land
-                               and c.template.cmc > len(me.untapped_lands) + 2]
-                if len(me.lands) >= 5:
-                    extra_lands = [c for c in me.hand if c.template.is_land]
-                    discardable.extend(extra_lands[:2])
+                # H2 fix: discard to pump, but protect key interaction.
+                # Priority: excess lands > duplicates on board > high-CMC
+                # Never discard: removal, counterspells
+                hand_lands = [c for c in me.hand if c.template.is_land]
+                hand_spells = [c for c in me.hand if not c.template.is_land]
+                board_names = {c.name for c in me.battlefield}
+
+                protect_tags = {'removal', 'counterspell'}
+                discardable = []
+
+                # 1. Excess lands (keep 1 for next land drop)
+                if len(hand_lands) >= 2 and len(me.lands) >= 3:
+                    discardable.extend(hand_lands[1:])
+                elif len(hand_lands) >= 1 and len(me.lands) >= 5:
+                    discardable.extend(hand_lands)
+
+                # 2. Duplicate of a card already on the battlefield
+                for c in hand_spells:
+                    tags = getattr(c.template, 'tags', set())
+                    if c.name in board_names and not (tags & protect_tags):
+                        if c not in discardable:
+                            discardable.append(c)
+
+                # 3. High-CMC spells we can't cast soon (CMC > lands + 1),
+                #    but NOT removal or counterspells
+                if len(hand_spells) >= 3:
+                    for c in hand_spells:
+                        tags = getattr(c.template, 'tags', set())
+                        if (tags & protect_tags):
+                            continue
+                        if (c.template.cmc or 0) > len(me.lands) + 1:
+                            if c not in discardable:
+                                discardable.append(c)
+
+                # Patch 12: when Frog is already pumped and opp is low,
+                # also discard cheap cantrips (we'll draw on damage)
+                if creature.plus_counters >= 1 and opp.life <= 12:
+                    for c in sorted(hand_spells, key=lambda x: x.template.cmc or 0):
+                        tags = getattr(c.template, 'tags', set())
+                        if (tags & protect_tags):
+                            continue
+                        if ('cantrip' in tags or 'draw' in tags) and c not in discardable:
+                            discardable.append(c)
+                            break
+
                 pumps = min(len(discardable), 2)
                 for i in range(pumps):
                     card_to_discard = discardable[i]
@@ -660,8 +727,8 @@ class EVPlayer:
                         me.hand.remove(card_to_discard)
                         card_to_discard.zone = "graveyard"
                         me.graveyard.append(card_to_discard)
-                        creature.temp_power_mod += 1
-                        creature.temp_toughness_mod += 1
+                        # H2 fix: use permanent +1/+1 counters, not temp mods
+                        creature.plus_counters += 1
                 break
 
         # Lethal: alpha strike
@@ -680,6 +747,9 @@ class EVPlayer:
             attack_plan, score_delta = self.combat_planner.plan_attack(vboard)
 
             threshold = self.profile.attack_threshold
+            # Patch E: when opponent is low, attack more aggressively
+            if opp.life <= 10 and self.archetype in ('aggro', 'tempo'):
+                threshold -= 2.0  # accept worse trades to close the game
 
             if attack_plan and score_delta > threshold:
                 attack_ids = {vc.instance_id for vc in attack_plan}
@@ -827,13 +897,17 @@ class EVPlayer:
                             best_kill_id = c.instance_id
 
             # Compare: is killing a creature worth more than face damage?
-            # For aggro: face is worth ~1.5 per damage point when opp > 10
-            # A creature kill is worth its creature_value
+            # P11: factor in the creature's clock — only for major threats (5+ power)
             face_val = dmg * self.profile.burn_face_mult
             if opp.life <= 10:
                 face_val = dmg * self.profile.burn_face_low_life_mult
+            adjusted_kill_val = best_kill_val
+            if best_kill_id:
+                kill_creature = next((c for c in opp.creatures if c.instance_id == best_kill_id), None)
+                if kill_creature and (kill_creature.power or 0) >= 5:
+                    adjusted_kill_val += (kill_creature.power or 0) * 1.0
 
-            if best_kill_id and best_kill_val > face_val:
+            if best_kill_id and adjusted_kill_val > face_val:
                 return [best_kill_id]  # kill the creature
             return [-1]  # go face
 
